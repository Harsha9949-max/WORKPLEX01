{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the WorkPlex platform",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "age": { "type": "number" },
        "venture": { "type": "string" },
        "role": { "type": "string" },
        "upiId": { "type": "string" },
        "bankAccount": { "type": "string" },
        "aadhaar": { "type": "string" },
        "pan": { "type": "string" },
        "deviceFingerprint": { "type": "string" },
        "level": { "type": "string" },
        "streak": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "contractSigned": { "type": "boolean" },
        "kycDone": { "type": "boolean" },
        "firstTaskDone": { "type": "boolean" },
        "wallets": {
          "type": "object",
          "properties": {
            "earned": { "type": "number" },
            "pending": { "type": "number" },
            "bonus": { "type": "number" },
            "savings": { "type": "number" },
            "temp": { "type": "number" }
          }
        },
        "preferredLanguage": { "type": "string" },
        "tempPhone": { "type": "string" },
        "phoneVerified": { "type": "boolean" },
        "kycDeferred": { "type": "boolean" },
        "kycCompletedAt": { "type": "string", "format": "date-time" },
        "tempWalletCap": { "type": "number" },
        "profileCompletion": { "type": "number" },
        "trustPoints": { "type": "number" },
        "firstEarningCompleted": { "type": "boolean" },
        "amlFlag": { "type": "boolean" }
      },
      "required": ["name", "phone", "age", "venture", "role", "deviceFingerprint", "level", "streak", "joinedAt", "wallets"]
    },
    "AICache": {
      "title": "AICache",
      "description": "Cache for AI responses to save costs and improve performance",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "data": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "data", "createdAt", "expiresAt"]
    },
    "FraudAlert": {
      "title": "FraudAlert",
      "description": "Alerts generated by AI fraud detection system",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "fraudScore": { "type": "number" },
        "indicators": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "suspended", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workerId", "fraudScore", "indicators", "status", "createdAt"]
    },
    "AIError": {
      "title": "AIError",
      "description": "Logs for AI related errors",
      "type": "object",
      "properties": {
        "function": { "type": "string" },
        "error": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["function", "error", "timestamp"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Public-facing profile for a worker",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "venture": { "type": "string" },
        "role": { "type": "string" },
        "level": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "totalEarned": { "type": "number" },
        "streakRecord": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "shopUrl": { "type": "string", "format": "uri" }
      },
      "required": ["uid", "displayName", "venture", "role", "level", "badges", "streakRecord", "joinedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Message in a team chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "readBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["senderId", "senderName", "text", "timestamp"]
    },
    "LiveFeedItem": {
      "title": "LiveFeedItem",
      "description": "Item in the real-time activity feed",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "source": { "type": "string" },
        "venture": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "amount", "source", "venture", "timestamp"]
    },
    "FamilyTransfer": {
      "title": "FamilyTransfer",
      "description": "UPI transfer to a family member",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "recipientUpi": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "paid", "rejected"] },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "recipientUpi", "amount", "status", "type", "createdAt"]
    },
    "PartnerShop": {
      "title": "PartnerShop",
      "description": "Information about a partner's white-label shop",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "shopSlug": { "type": "string" },
        "logo": { "type": "string", "format": "uri" },
        "ownerUID": { "type": "string" },
        "isActive": { "type": "boolean" },
        "totalSales": { "type": "number" },
        "categories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["shopName", "shopSlug", "ownerUID", "isActive", "categories"]
    },
    "PartnerProduct": {
      "title": "PartnerProduct",
      "description": "Product listing within a partner's shop",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "hvrsBasePrice": { "type": "number" },
        "partnerSellingPrice": { "type": "number" },
        "partnerMargin": { "type": "number" },
        "productData": { "type": "object" },
        "isActive": { "type": "boolean" }
      },
      "required": ["productId", "hvrsBasePrice", "partnerSellingPrice", "partnerMargin", "productData", "isActive"]
    },
    "PartnerOrder": {
      "title": "PartnerOrder",
      "description": "Customer order from a partner shop",
      "type": "object",
      "properties": {
        "shopSlug": { "type": "string" },
        "customerId": { "type": "string" },
        "customerDetails": { "type": "object" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "totalPartnerMargin": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "marginStatus": { "type": "string", "enum": ["holding", "released"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopSlug", "customerDetails", "items", "totalAmount", "totalPartnerMargin", "status", "marginStatus", "createdAt"]
    },
    "CatalogProduct": {
      "title": "CatalogProduct",
      "description": "Master product in HVRS catalog",
      "type": "object",
      "properties": {
        "SKU": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "hvrsBasePrice": { "type": "number" },
        "suggestedRetailPrice": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" }
      },
      "required": ["SKU", "name", "category", "hvrsBasePrice", "suggestedRetailPrice", "isActive"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Administrator account with specific permissions",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["SuperAdmin", "SubAdmin"] },
        "assignedVentures": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "assignedVentures", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task assigned to workers",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "venture": { "type": "string" },
        "targetRoles": { "type": "array", "items": { "type": "string" } },
        "earningAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "proofType": { "type": "string", "enum": ["Image", "Link", "Text"] },
        "assignedTo": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "deleted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "venture", "targetRoles", "earningAmount", "deadline", "proofType", "status", "createdAt"]
    },
    "TaskSubmission": {
      "title": "TaskSubmission",
      "description": "A submission for a task by a worker",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "taskId": { "type": "string" },
        "taskTitle": { "type": "string" },
        "proofData": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workerId", "workerName", "taskId", "taskTitle", "proofData", "status", "submittedAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "A withdrawal request from a worker",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "upiId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "paid", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "amount", "upiId", "status", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A promotional coupon for workers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "workerName": { "type": "string" },
        "venture": { "type": "string" },
        "code": { "type": "string" },
        "isActive": { "type": "boolean" },
        "usesToday": { "type": "number" },
        "totalEarned": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "workerName", "venture", "code", "isActive", "usesToday", "totalEarned", "expiresAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "A broadcasted message for workers",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "audience": { "type": "string" },
        "targetVenture": { "type": "string" },
        "targetRole": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "audience", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Administrator accounts"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Platform tasks"
    },
    "/taskSubmissions/{submissionId}": {
      "schema": { "$ref": "#/entities/TaskSubmission" },
      "description": "Worker submissions for tasks"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": { "$ref": "#/entities/Withdrawal" },
      "description": "Worker withdrawal requests"
    },
    "/coupons/{userId}": {
      "schema": { "$ref": "#/entities/Coupon" },
      "description": "Worker promotional coupons"
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Broadcasted announcements"
    },
    "/aiCache/{cacheId}": {
      "schema": { "$ref": "#/entities/AICache" },
      "description": "AI response cache"
    },
    "/fraudAlerts/{alertId}": {
      "schema": { "$ref": "#/entities/FraudAlert" },
      "description": "Fraud detection alerts"
    },
    "/aiErrors/{errorId}": {
      "schema": { "$ref": "#/entities/AIError" },
      "description": "AI error logs"
    },
    "/publicProfiles/{username}": {
      "schema": { "$ref": "#/entities/PublicProfile" },
      "description": "Publicly accessible profiles"
    },
    "/teamChats/{leadId}/messages/{msgId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Team group chat messages"
    },
    "/liveFeed/{feedId}": {
      "schema": { "$ref": "#/entities/LiveFeedItem" },
      "description": "Global activity feed items"
    },
    "/familyTransfers/{transferId}": {
      "schema": { "$ref": "#/entities/FamilyTransfer" },
      "description": "Family UPI transfer requests"
    },
    "/partnerShops/{partnerId}": {
      "schema": { "$ref": "#/entities/PartnerShop" },
      "description": "Details of partner shops"
    },
    "/partnerProducts/{partnerId}/products/{productId}": {
      "schema": { "$ref": "#/entities/PartnerProduct" },
      "description": "Partner-specific product pricing"
    },
    "/partnerOrders/{orderId}": {
      "schema": { "$ref": "#/entities/PartnerOrder" },
      "description": "Orders placed via partner shops"
    },
    "/catalogProducts/{productId}": {
      "schema": { "$ref": "#/entities/CatalogProduct" },
      "description": "Master catalog products"
    }
  }
}
