rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // 0. Global Safety Net & Catch-All
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // 3. Helper Functions (Primitives)
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'marateyh@gmail.com' ||
        request.auth.token.email == 'hvrsindustriespvtltd@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'marateyh@gmail.com' || 
        request.auth.token.email == 'hvrsindustriespvtltd@gmail.com'
      ) && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // 4. ENTITY RULES
    // ===============================================================

    match /suspiciousActivity/{activityId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile, Admins can read all. 
      // Public profile fields are handled by publicProfiles check.
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation of the user document on registration only once
      allow create: if isOwner(userId) && !exists(/databases/$(database)/documents/users/$(userId));
      
      // Allow updates to profile and state
      allow update: if (isOwner(userId) && (
        // Action: Profile Update (Onboarding & Profile Screen)
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'phone', 'age', 'venture', 'role', 'upiId', 'bankAccount', 
          'photoURL', 'preferredLanguage', 'kycDeferred', 'profileCompletion',
          'lastActiveDate', 'streak', 'username', 'bio'
        ]) ||
        // Action: Trust Points (Validated by system, but user might sync)
        incoming().diff(existing()).affectedKeys().hasOnly(['trustPoints']) ||
        // Action: Self-Update of Temp Wallet (Small amounts only)
        (incoming().diff(existing()).affectedKeys().hasOnly(['wallets']) && incoming().wallets.temp <= 1000) ||
        // Action: Full Update if KYC is done
        (existing().get('kycCompletedAt', null) != null)
      )) || isAdmin();

      allow delete: if isSuperAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == adminId);
      allow write: if isSuperAdmin();
    }

    match /tasks/{taskId} {
      // Tasks are public for all authenticated users to browse and accept
      allow read: if isAuthenticated();
      // Only admins can create/edit/delete tasks
      allow write: if isAdmin();
    }

    match /taskSubmissions/{submissionId} {
      // Workers can see their own submissions; Admins can see all.
      // List query must include workerId filter for workers.
      allow read: if isAuthenticated() && (existing().workerId == request.auth.uid || isAdmin());
      // Workers can create submissions for themselves
      allow create: if isAuthenticated() && incoming().workerId == request.auth.uid && isValidId(incoming().taskId);
      // Only admins can approve/reject
      allow update: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      // Only the requester or admin can see the withdrawal
      allow read: if isAuthenticated() && (existing().uid == request.auth.uid || isAdmin());
      // Minimum condition: KYC must be completed to withdraw
      allow create: if isAuthenticated() && incoming().uid == request.auth.uid && 
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.kycCompletedAt != null;
      allow update: if isAdmin();
    }

    match /coupons/{userId} {
      // Public read for applying coupons (or restricted if needed)
      allow read: if true;
      allow write: if isAdmin() || isOwner(userId);
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /publicProfiles/{username} {
      // Everyone can see public profiles
      allow read: if true;
      // Managed by Cloud Functions to ensure sync with User document
      allow write: if false;
    }

    match /teamChats/{leadId}/messages/{msgId} {
      // Participants in the chat can read (simplified roles for now)
      allow read: if isAuthenticated();
      // Only sender can create their message
      allow create: if isAuthenticated() && incoming().senderId == request.auth.uid;
    }

    match /liveFeed/{feedId} {
      allow read: if true;
      allow write: if false; // System only
    }

    match /partnerShops/{partnerId} {
      allow read: if true;
      allow write: if isOwner(partnerId);
    }

    match /partnerProducts/{partnerId}/products/{productId} {
      allow read: if true;
      allow write: if isOwner(partnerId);
    }

    match /partnerOrders/{orderId} {
      // Shop owners (partners) should be able to see their shop's orders
      // In this app, we need to verify the partner's ownership.
      allow read: if isAuthenticated() && (
        existing().customerId == request.auth.uid || 
        isAdmin() ||
        // Allow the shop owner to read orders for their shop slug
        // Note: shopSlug is in existing(), we can verify with PartnerShop
        exists(/databases/$(database)/documents/partnerShops/$(request.auth.uid))
      );
      allow create: if true; // Public checkout
      allow update: if isAdmin();
    }

    match /catalogProducts/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /aiCache/{cacheId} {
      allow read, write: if false; // System only
    }

    match /fraudAlerts/{alertId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /aiErrors/{errorId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    match /familyTransfers/{transferId} {
      allow read: if isOwner(existing().senderId);
      allow create: if isOwner(incoming().senderId);
    }
  }
}
